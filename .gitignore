cd C:\java-backend1

# Create correct .gitignore file
@'
# Compiled files
target/
*.class

# IDE files
.vscode/
.idea/
*.iml

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Application files
*.jar
*.war
*.ear
!*.jar

# Maven wrapper files - COMMENT THESE OUT if you want to include them
# .mvn/
# mvnw
# mvnw.cmd

# Test files
src/test/
'@ | Out-File -FilePath .gitignore -Encoding UTF8

# Verify
cat .gitignore